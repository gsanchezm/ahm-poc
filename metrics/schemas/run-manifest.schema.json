{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tom-architecture/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "generatedAt",
    "commitSha",
    "branch",
    "ciProvider",
    "ciRunId",
    "platform",
    "viewport",
    "driver",
    "tags",
    "environment",
    "nodeVersion",
    "os"
  ],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "commitSha": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "ciProvider": { "type": ["string", "null"] },
    "ciRunId": { "type": ["string", "null"] },
    "platform": { "type": "string" },
    "viewport": { "type": ["string", "null"] },
    "driver": { "type": ["string", "null"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "environment": { "type": ["string", "null"] },
    "nodeVersion": { "type": ["string", "null"] },
    "os": { "type": ["string", "null"] }
  }
}
