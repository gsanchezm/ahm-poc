{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tom-architecture/schemas/visual-contract-event.schema.json",
  "title": "VisualContractTelemetryEvent",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "runId",
    "timestamp",
    "feature",
    "contractType",
    "snapshotId",
    "regionRef",
    "resolvedRegionStrategy",
    "maskRefs",
    "resolvedMaskCount",
    "platform",
    "viewport",
    "status",
    "durationMs",
    "baselinePath",
    "actualPath",
    "diffPath",
    "diffPixels",
    "diffRatio",
    "threshold",
    "passed",
    "errorMessage",
    "metadata"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string" },
    "timestamp": { "type": "string" },
    "feature": { "type": "string" },
    "contractType": { "const": "VISUAL" },
    "contractId": { "type": "string" },
    "snapshotId": { "type": "string" },
    "regionRef": { "type": "string" },
    "resolvedRegionStrategy": { "type": ["string", "null"] },
    "maskRefs": { "type": "array", "items": { "type": "string" } },
    "resolvedMaskCount": { "type": "integer", "minimum": 0 },
    "platform": { "type": ["string", "null"] },
    "viewport": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIP", "UNKNOWN"] },
    "durationMs": { "type": ["number", "null"] },
    "baselinePath": { "type": ["string", "null"] },
    "actualPath": { "type": ["string", "null"] },
    "diffPath": { "type": ["string", "null"] },
    "diffPixels": { "type": ["number", "null"] },
    "diffRatio": { "type": ["number", "null"] },
    "threshold": { "type": ["number", "null"] },
    "passed": { "type": ["boolean", "null"] },
    "errorMessage": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}
