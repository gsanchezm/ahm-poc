{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tom-architecture/schemas/scenario-inventory.schema.json",
  "title": "ScenarioInventoryEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "featureFile",
    "featureName",
    "scenarioName",
    "scenarioType",
    "tags",
    "exampleRows",
    "steps"
  ],
  "properties": {
    "featureFile": { "type": "string" },
    "featureName": { "type": "string" },
    "scenarioName": { "type": "string" },
    "scenarioType": {
      "type": "string",
      "enum": ["Scenario", "ScenarioOutline"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exampleRows": { "type": "integer", "minimum": 0 },
    "steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
