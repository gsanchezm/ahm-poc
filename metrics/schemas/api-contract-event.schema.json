{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tom-architecture/schemas/api-contract-event.schema.json",
  "title": "ApiContractTelemetryEvent",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "runId",
    "timestamp",
    "feature",
    "contractType",
    "endpointId",
    "method",
    "path",
    "platform",
    "status",
    "durationMs",
    "requestHeadersHash",
    "requestBodyHash",
    "responseStatus",
    "responseTimeMs",
    "extractedKeys",
    "assertionCount",
    "failedAssertions",
    "errorMessage",
    "metadata"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string" },
    "timestamp": { "type": "string" },
    "feature": { "type": "string" },
    "contractType": { "const": "API" },
    "contractId": { "type": "string" },
    "endpointId": { "type": "string" },
    "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    "path": { "type": "string" },
    "platform": { "type": ["string", "null"] },
    "viewport": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIP", "UNKNOWN"] },
    "durationMs": { "type": ["number", "null"] },
    "requestHeadersHash": { "type": ["string", "null"] },
    "requestBodyHash": { "type": ["string", "null"] },
    "responseStatus": { "type": ["number", "null"] },
    "responseTimeMs": { "type": ["number", "null"] },
    "extractedKeys": { "type": "array", "items": { "type": "string" } },
    "assertionCount": { "type": "integer", "minimum": 0 },
    "failedAssertions": { "type": "integer", "minimum": 0 },
    "errorMessage": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}
